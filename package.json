{
  "name": "client-name",
  "version": "1.0.0",
  "description": "WordPress theme build scripts.",
  "scripts": {
    "bs": "browser-sync start --config assets/build/browser-sync.config.js",
    "css": "npm-run-all css-compile css-postcss css-minify",
    "css-compile": "sass --style expanded --source-map --embed-sources --no-error-css --quiet assets/sass:assets/css",
    "css-minify": "cleancss -O1 --format breakWith=lf --with-rebase --source-map --source-map-inline-sources --output assets/css/ --batch --batch-suffix \".min\" \"assets/css/*.css\" \"!assets/css/*.min.css\"",
    "css-postcss": "postcss --config assets/build/postcss.config.js --replace \"assets/css/*.css\" \"!assets/css/*.min.css\"",
    "watch": "npm-run-all --parallel watch-run-*",
    "watch-bs": "npm-run-all --parallel bs watch-run-*",
    "js-minify": "for f in assets/js/*.js; do case \"$f\" in *.min.js) ;; *) terser \"$f\" -o \"${f%.js}.min.js\" --compress --mangle;; esac; done",
    "watch-run-css": "nodemon --watch assets/sass/ --ext scss --exec \"npm-run-all css\"",
    "watch-run-js": "nodemon --watch assets/js/ --ext js --ignore \"assets/js/*.min.js\" --exec \"npm-run-all js-minify\""
  },
  "engines": {
    "node": ">=18"
  },
  "license": "GPL-3.0",
  "browserslist": [
    "last 2 versions",
    "> 1%",
    "not dead"
  ],
  "dependencies": {},
  "devDependencies": {
    "@popperjs/core": "^2.11.6",
    "autoprefixer": "^10.4.13",
    "bootstrap": "^5.2.2",
    "browser-sync": "^3.0.4",
    "browserslist": "^4.21.4",
    "caniuse-lite": "^1.0.30001430",
    "clean-css-cli": "^5.6.1",
    "nodemon": "^3.1.14",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.10",
    "postcss-cli": "^10.0.0",
    "sass": "^1.56.0",
    "terser": "^5.15.1"
  }
}
