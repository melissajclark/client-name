{
	"version": 3,
	"settings": {
		"appearanceTools": false,
		"blocks": {
            "core/button": {
                "width" : [],
                "border": {
                    "color": false,
                    "radius": false,
                    "style": false,
                    "width": false
                },
                "typography": {
					"textTransform" : true
                },
				"color" : {
					"background" : false
				}
            },
			"core/group": {
				"color": {
					"background": true
				}
			}
        },
		"color": {
			"text": false,
			"background": false,
			"custom": false,
			"customDuotone": false,
			"customGradient": false,
			"defaultDuotone": false,
			"defaultGradients": false,
			"defaultPalette": false,
			"gradients" : [],
            "link": false,
			"palette": [
				{
					"slug": "white",
					"color": "#fff",
					"name": "White"
				},
				{
					"slug": "black",
					"color": "#000",
					"name": "black"
				},
				{
					"slug": "purple",
					"color": "#7a359b",
					"name": "purple"
				}
			]
		},
		"layout": {
			"contentSize": "860px",
			"wideSize": "1200px"
		},
		"spacing": {
			"blockGap": null,
			"margin": false,
			"padding": false,
			"units": [],
			"customSpacingSize": false
		},
		"typography": {
			"defaultFontSizes": false,
			"customFontSize": false,
			"fontStyle": false,
			"fontWeight": false,
			"fluid" : false,
			"letterSpacing": false,
			"lineHeight": false,
			"textDecoration": false,
			"textTransform": true,
			"dropCap": false,
			"fontFamilies": []
		},
		"custom": {
			"button" : {
				"background" : "var(--wp--preset--color--black)",
				"border" : "var(--wp--preset--color--black)",
				"border-width" : "3px",
				"border-radius" : "20px",
				"text" : "var(--wp--preset--color--white)",
				"text-size" : "1rem",
				"padding" : "0.49rem 1.1rem"
			},
			"button-hover" : {
				"background" : "var(--wp--preset--color--purple)",
				"border" : "var(--wp--preset--color--purple)",
				"text" : "var(--wp--preset--color--white)"
			},
			"button-focus" : {
				"background" : "var(--wp--preset--color--black)",
				"border" : "var(--wp--preset--color--black)",
				"outline" : "var(--wp--preset--color--purple)",
				"text" : "var(--wp--preset--color--white)"
			},
			"form" : {
				"input-background" : "var(--wp--preset--color--black)",
				"input-border" : "var(--wp--preset--color--white)",
				"input-outline" : "var(--wp--preset--color--black)"
			},
			"font-family" : {
				"body" : "\"Georgia\",serif",
				"headings" : "\"Arial\",sans-serif"
			},
			"font-size" : {
				"body" : "1.25rem"
			},
			"heading-size" : {
				"1" : "4rem",
				"2" : "3rem",
				"3" : "2.25rem"
			},
			"space" : {
				"vertical" : "1rem" 
			}
		},
		"useRootPaddingAwareAlignments": false
	},
	"styles": {
		"blocks": {
			"core/button": {
				"border" : {
					"color" : "var(--wp--custom--button--border)",
					"radius" : "var(--wp--custom--button--border-radius)",
					"style" : "solid",
					"width": "var(--wp--custom--button--border-width)"
				},
				"color": {
					"background": "var(--wp--custom--button--background)",
					"text": "var(--wp--custom--button--text)"
				},
				"typography": {
					"fontFamily" : "var(--wp--custom--font-family--headings)",
					"fontSize": "var(--wp--custom--button--text-size)",
					"letterSpacing" : "",
					"fontWeight" : "",
					"lineHeight" : ""
				},
				":hover":{
					"color": {
						"background": "var(--wp--custom--button-hover--background)",
						"text": "var(--wp--custom--button-hover--text)"
					}
				},
				":focus":{
					"color": {
						"background": "var(--wp--custom--button-focus--background)",
						"text": "var(--wp--custom--button-focus--text)"
					},
					"outline": {
						"color": "var(--wp--preset--color--purple)"
					}
				},
				"spacing": {
					"padding": "var(--wp--custom--button--padding)"
				}
			},
			"core/heading": {
				"typography": {
					"fontFamily" : "var(--wp--custom--font-family--headings)",
					"lineHeight" : "1.35"
				}
			},
			"core/group": {
				"spacing" : {
					"padding": {
						"top" : "var(--wp--custom--space--vertical)",
						"bottom" : "var(--wp--custom--space--vertical)"
					}
				}
			},
			"core/post-title": {
				"typography": {
					"fontSize" : "var(--wp--custom--heading-size--1)",
					"fontFamily" : "var(--wp--custom--font-family--headings)"
				}
			}
		},
		"color": {
			"background": "var(--wp--preset--color--white)",
			"text": "var(--wp--preset--color--black)"
		},
		"elements": {
			"caption" : {
				"typography": {
					"fontSize": "calc( var(--wp--custom--font-size--body) * 0.8)",
					"fontFamily": "var(--wp--custom--font-family--body)",
					"lineHeight": "1.5"
				}
			},
			"h1" : {
				"typography": {
					"fontSize" : "var(--wp--custom--heading-size--1)"
				}
			},
			"h2" : {
				"typography": {
					"fontSize" : "var(--wp--custom--heading-size--2)"
				}
			},
			"h3" : {
				"typography": {
					"fontSize" : "var(--wp--custom--heading-size--3)"
				}
			},
			"h4" : {
				"typography": {
					"fontSize" : "var(--wp--custom--heading-size--4)"
				}
			},
			"h5" : {
				"typography": {
					"fontSize" : "var(--wp--custom--heading-size--5)"
				}
			},
			"h6" : {
				"typography": {
					"fontSize" : "var(--wp--custom--heading-size--6)"
				}
			},
			"link": {
				"color": {
					"text": "currentColor"
				},
				"typography": {
					"textDecoration": "underline"
				},
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--purple)"
					},
					"typography": {
						"textDecoration": "underline"
					}
				},
				":focus": {
					"color": {
						"text": "var(--wp--preset--color--purple)"
					},
					"typography": {
						"textDecoration": "none"
					},
					"outline": {
						"width": "1px",
						"color": "var(--wp--preset--color--purple)"
					}
				}
			}
		},
		"spacing":{
			"blockGap": "var(--wp--custom--space--vertical)"
		},
		"typography": {
			"fontSize": "var(--wp--custom--font-size--body)",
			"fontFamily": "var(--wp--custom--font-family--body)",
			"lineHeight": "1.5"
		}
	},
	"templateParts": [
		{
			"name": "header",
			"title": "Header",
			"area": "header"
		},
		{
			"name": "footer",
			"title": "Footer",
			"area": "footer"
		}
	]
}
